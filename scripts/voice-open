#!/data/data/com.termux/files/usr/bin/bash
# Voice-controlled app launcher (Whisper backend)

set -e

declare -A APPS=(
    ["whatsapp"]="com.whatsapp/.Main"
    ["whats app"]="com.whatsapp/.Main"
    ["youtube"]="com.google.android.youtube"
    ["you tube"]="com.google.android.youtube"
    ["chrome"]="com.android.chrome"
    ["gmail"]="com.google.android.gm"
    ["maps"]="com.google.android.apps.maps"
    ["google maps"]="com.google.android.apps.maps"
    ["calendar"]="com.google.android.calendar"
    ["settings"]="com.android.settings"
    ["camera"]="com.nothing.snap"
    ["clock"]="com.nothing.clock"
    ["photos"]="com.google.photos"
    ["google photos"]="com.google.photos"
    ["spotify"]="com.spotify.music"
    ["instagram"]="com.instagram.android"
    ["telegram"]="org.telegram.messenger"
    ["termux"]="com.termux"
)

launch_app() {
    local target="$1"
    if [[ "$target" == *"/"* ]]; then
        am start -n "$target" > /dev/null 2>&1
    else
        am start -a android.intent.action.MAIN \
                 -c android.intent.category.LAUNCHER \
                 -p "$target" > /dev/null 2>&1
    fi
}

MAX_ATTEMPTS=3
attempt=1

# If pre-captured text passed as $1, use it for the first attempt
PRE_TEXT="$1"

while [ $attempt -le $MAX_ATTEMPTS ]; do
    if [ -n "$PRE_TEXT" ] && [ $attempt -eq 1 ]; then
        TEXT="$PRE_TEXT"
    else
        echo "🎤 Attempt $attempt: say app name (5 seconds)"
        TEXT=$(whisper-listen 5)
    fi

    if [ -z "$TEXT" ]; then
        echo "⚠️  No speech detected"
        attempt=$((attempt + 1))
        continue
    fi

    echo "Heard: $TEXT"
    TEXT_LOWER=$(echo "$TEXT" | tr '[:upper:]' '[:lower:]')

    MATCHED_TARGET=""
    MATCHED_NAME=""
    for keyword in "${!APPS[@]}"; do
        if [[ "$TEXT_LOWER" == *"$keyword"* ]]; then
            MATCHED_TARGET="${APPS[$keyword]}"
            MATCHED_NAME="$keyword"
            break
        fi
    done

    if [ -n "$MATCHED_TARGET" ]; then
        MSG="Opening $MATCHED_NAME"
        echo "📱 $MSG ($MATCHED_TARGET)"
        if launch_app "$MATCHED_TARGET"; then
            termux-toast "$MSG"
            termux-tts-speak "$MSG" 2>/dev/null &
            ~/bin/voice-context write last_action open
            ~/bin/voice-context write last_app_opened "$MATCHED_NAME"
            exit 0
        else
            MSG="Launch failed: $MATCHED_NAME"
            echo "❌ $MSG"
            termux-toast "$MSG"
            termux-tts-speak "$MSG" 2>/dev/null &
            exit 1
        fi
    fi

    echo "⚠️  No matching app — try again"
    attempt=$((attempt + 1))
done

MSG="Could not identify app"
termux-toast "$MSG"
termux-tts-speak "$MSG" 2>/dev/null &
echo "❌ Gave up after $MAX_ATTEMPTS attempts"
exit 1
