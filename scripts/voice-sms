#!/data/data/com.termux/files/usr/bin/bash
# Voice-controlled SMS/RCS — read latest messages or send a new one
# Tries RCS (Google Messages bugle_db) first, falls back to traditional SMS
# Requires: SMS + Contacts permissions granted to Termux:API, root for RCS

set -e

SQLITE3="/data/data/com.termux/files/usr/bin/sqlite3"

# Accept pre-captured text as $1 or listen fresh
if [ -n "$1" ]; then
    TEXT="$1"
else
    echo "🎤 Say: 'read messages' or 'send message' or 'text [name]'"
    TEXT=$(~/bin/whisper-listen 5 | tr -d '\r\n')
fi

if [ -z "$TEXT" ]; then
    echo "❌ Nothing heard"
    termux-toast "No command captured"
    exit 1
fi

echo "Heard: $TEXT"
T=$(echo "$TEXT" | tr '[:upper:]' '[:lower:]')

# Helper: speak and echo
say() {
    echo "  $1"
    termux-tts-speak "$1" 2>/dev/null
}

# Helper: look up contact name from number
lookup_contact() {
    local NUM="$1"
    local SHORT=$(echo "$NUM" | sed 's/[^0-9]//g' | tail -c 8)
    termux-contact-list 2>/dev/null | python3 -c "
import json, sys, re
contacts = json.load(sys.stdin)
num = '$SHORT'
for c in contacts:
    clean = re.sub(r'[^0-9]', '', c.get('number',''))
    if clean.endswith(num) or num.endswith(clean[-7:]):
        print(c.get('name', ''))
        sys.exit(0)
print('')
" 2>/dev/null
}

# Helper: look up phone number from contact name
lookup_number() {
    local NAME="$1"
    termux-contact-list 2>/dev/null | python3 -c "
import json, sys
contacts = json.load(sys.stdin)
query = '$NAME'.lower()
for c in contacts:
    if query in c.get('name','').lower():
        print(c.get('name','') + '|' + c.get('number',''))
        sys.exit(0)
print('')
" 2>/dev/null
}

# ─── READ MESSAGES ────────────────────────────────────────
if [[ "$T" == *"read"* || "$T" == *"latest"* || "$T" == *"any message"* || "$T" == *"inbox"* ]]; then
    echo "📨 Reading messages..."

    # Try RCS (Google Messages bugle_db) first, then fall back to SMS
    RCS_FOUND=0
    BUGLE="/data/data/com.google.android.apps.messaging/databases/bugle_db"
    TMP_DB="/data/local/tmp/bugle_copy.db"

    if su -c "test -f '$BUGLE'" 2>/dev/null; then
        su -c "cp '$BUGLE' '$TMP_DB'; cp '${BUGLE}-wal' '${TMP_DB}-wal' 2>/dev/null; cp '${BUGLE}-shm' '${TMP_DB}-shm' 2>/dev/null; chmod 644 ${TMP_DB}*" 2>/dev/null

        # Query parts table for message text
        RCS_MSGS=$("$SQLITE3" "$TMP_DB" "
SELECT
    COALESCE(pr.full_name, pr.display_destination, 'Unknown'),
    p.text
FROM parts p
JOIN messages m ON p.message_id = m._id
LEFT JOIN participants pr ON m.sender_id = pr._id
WHERE p.text IS NOT NULL AND length(p.text) > 0
ORDER BY m.received_timestamp DESC
LIMIT 5" 2>/dev/null || true)

        # Fall back to conversation snippets if parts empty
        if [ -z "$RCS_MSGS" ]; then
            RCS_MSGS=$("$SQLITE3" "$TMP_DB" "
SELECT c.name, c.snippet_text
FROM conversations c
WHERE c.snippet_text IS NOT NULL AND length(c.snippet_text) > 0
    AND c.snippet_text NOT LIKE 'Texting with%'
ORDER BY c.sort_timestamp DESC
LIMIT 5" 2>/dev/null || true)
        fi

        rm -f "$TMP_DB" "${TMP_DB}-wal" "${TMP_DB}-shm" 2>/dev/null

        if [ -n "$RCS_MSGS" ]; then
            RCS_FOUND=1
            echo "  (source: Google Messages / RCS)"
            I=0
            echo "$RCS_MSGS" | while IFS='|' read -r SENDER MSG; do
                I=$((I + 1))
                if [ ${#MSG} -gt 200 ]; then
                    MSG="${MSG:0:200}... truncated"
                fi
                say "Message $I from $SENDER: $MSG"
            done
        fi
    fi

    # Fall back to traditional SMS if no RCS messages
    if [ "$RCS_FOUND" = "0" ]; then
        MESSAGES=$(timeout 10 termux-sms-list -l 5 2>/dev/null || echo "[]")
        COUNT=$(echo "$MESSAGES" | python3 -c "import json,sys; print(len(json.load(sys.stdin)))" 2>/dev/null || echo "0")

        if [ "$COUNT" = "0" ]; then
            say "No messages found."
            exit 0
        fi

        echo "  (source: SMS inbox)"
        echo "$MESSAGES" | python3 -c "
import json, sys
msgs = json.load(sys.stdin)
for i, m in enumerate(msgs[:3]):
    sender = m.get('sender', m.get('number', 'Unknown'))
    body = m.get('body', 'No content')
    if len(body) > 200:
        body = body[:200] + '... message truncated'
    print(f'Message {i+1} from {sender}: {body}')
" 2>/dev/null | while IFS= read -r line; do
            say "$line"
        done
    fi

# ─── SEND MESSAGE ─────────────────────────────────────────
elif [[ "$T" == *"send"* || "$T" == *"text"* || "$T" == *"sms"* ]]; then
    echo "📤 Send message"

    # Check if a name was included in the command
    CONTACT_NAME=$(echo "$TEXT" | sed -E 's/.*(text|send( a)?( message)?( to)?|sms( to)?)[[:space:]]+//i' | xargs)

    if [ -z "$CONTACT_NAME" ] || [ "$CONTACT_NAME" = "$TEXT" ]; then
        say "Who do you want to text?"
        CONTACT_NAME=$(~/bin/whisper-listen 5 | tr -d '\r\n')
    fi

    if [ -z "$CONTACT_NAME" ]; then
        say "No contact name heard. Cancelled."
        exit 1
    fi

    echo "  Looking up: $CONTACT_NAME"
    MATCH=$(lookup_number "$CONTACT_NAME")

    if [ -z "$MATCH" ]; then
        say "No contact found matching $CONTACT_NAME"
        exit 1
    fi

    MATCHED_NAME=$(echo "$MATCH" | cut -d'|' -f1)
    MATCHED_NUM=$(echo "$MATCH" | cut -d'|' -f2)
    echo "  Found: $MATCHED_NAME ($MATCHED_NUM)"

    say "What's your message to $MATCHED_NAME?"
    MSG_BODY=$(~/bin/whisper-listen 15 | tr -d '\r\n')

    if [ -z "$MSG_BODY" ]; then
        say "No message heard. Cancelled."
        exit 1
    fi

    echo "  Message: $MSG_BODY"
    say "Sending to $MATCHED_NAME: $MSG_BODY. Say yes to confirm."
    CONFIRM=$(~/bin/whisper-listen 5 | tr '[:upper:]' '[:lower:]' | tr -d '\r\n')

    if [[ "$CONFIRM" == *"yes"* || "$CONFIRM" == *"yeah"* || "$CONFIRM" == *"sure"* || "$CONFIRM" == *"send"* || "$CONFIRM" == *"confirm"* ]]; then
        termux-sms-send -n "$MATCHED_NUM" "$MSG_BODY"
        say "Message sent to $MATCHED_NAME."
    else
        say "Message cancelled."
    fi

else
    say "Say 'read messages' or 'send message to someone'"
    exit 1
fi
