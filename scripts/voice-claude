#!/data/data/com.termux/files/usr/bin/env python3
"""
voice-claude — Claude API integration for voice assistant
Sends voice input to Claude API with tool definitions
Claude decides: answer directly OR execute a tool
"""
import warnings
warnings.filterwarnings("ignore")

import os
import sys
import json
import subprocess
import urllib.request
import urllib.error
import time
from datetime import datetime
from pathlib import Path

HOME = Path.home()
API_KEY_FILE = HOME / ".anthropic_key"
HISTORY_FILE = HOME / ".voice-claude-history.json"
LOG_FILE = HOME / "logs" / "voice-claude.log"
HISTORY_TTL = 600  # 10 minutes

LOG_FILE.parent.mkdir(exist_ok=True)

def log(msg):
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    line = f"[{ts}] {msg}"
    print(line, flush=True)
    try:
        with open(LOG_FILE, "a") as f:
            f.write(line + "\n")
    except Exception:
        pass

def say(text):
    log(f"TTS: {text}")
    subprocess.run(["termux-tts-speak", text])

# Load API key
if not API_KEY_FILE.exists():
    say("Claude API key not configured")
    sys.exit(1)

API_KEY = API_KEY_FILE.read_text().strip()
if not API_KEY:
    say("Claude API key is empty")
    sys.exit(1)

def load_history():
    if HISTORY_FILE.exists():
        try:
            data = json.loads(HISTORY_FILE.read_text())
            if time.time() - data.get("timestamp", 0) < HISTORY_TTL:
                return data.get("messages", [])
        except Exception:
            pass
    return []

def save_history(messages):
    try:
        HISTORY_FILE.write_text(json.dumps({
            "timestamp": time.time(),
            "messages": messages[-10:]
        }))
    except Exception:
        pass

def clear_history():
    HISTORY_FILE.unlink(missing_ok=True)

