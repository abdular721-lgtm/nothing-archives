#!/data/data/com.termux/files/usr/bin/bash
# Control script for the Hey Nothing wake word daemon
# Usage: hey-nothing-ctl start|stop|status|restart

PID_FILE="$HOME/.hey-nothing.pid"
STATS_FILE="$HOME/.hey-nothing-stats.json"
CONFIG_FILE="$HOME/.hey-nothing-config"
DAEMON="$HOME/bin/hey-nothing"
LOG_DIR="$HOME/logs"

mkdir -p "$LOG_DIR"

is_running() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE" 2>/dev/null)
        if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
            return 0
        fi
        # Stale PID file
        rm -f "$PID_FILE"
    fi
    return 1
}

do_start() {
    if is_running; then
        PID=$(cat "$PID_FILE")
        echo "Already running (PID $PID)"
        return 0
    fi

    TIMESTAMP=$(date +%s)
    LOG="$LOG_DIR/hey-nothing-${TIMESTAMP}.log"

    nohup "$DAEMON" </dev/null >"$LOG" 2>&1 &
    BG_PID=$!
    disown

    # Wait a moment to verify it started
    sleep 2
    if kill -0 $BG_PID 2>/dev/null; then
        echo "Hey Nothing daemon started (PID $BG_PID)"
        echo "Log: $LOG"
    else
        echo "Failed to start daemon. Check log: $LOG"
        cat "$LOG" 2>/dev/null
        return 1
    fi
}

do_stop() {
    if ! is_running; then
        echo "Not running"
        return 0
    fi

    PID=$(cat "$PID_FILE")
    echo "Stopping daemon (PID $PID)..."
    kill "$PID" 2>/dev/null

    # Wait up to 5 seconds for clean shutdown
    for i in 1 2 3 4 5; do
        if ! kill -0 "$PID" 2>/dev/null; then
            echo "Stopped."
            rm -f "$PID_FILE"
            return 0
        fi
        sleep 1
    done

    # Force kill
    kill -9 "$PID" 2>/dev/null
    rm -f "$PID_FILE"
    echo "Force stopped."
}

do_status() {
    echo "=== Hey Nothing Wake Word Daemon ==="
    echo "Method: openWakeWord (hey_jarvis model)"
    echo ""

    if is_running; then
        PID=$(cat "$PID_FILE")
        echo "Status: Running (PID $PID)"

        # Read JSON stats
        if [ -f "$STATS_FILE" ]; then
            # Parse JSON with python3 (always available on Termux)
            python3 -c "
import json, time
try:
    stats = json.load(open('$STATS_FILE'))
    now = time.time()
    uptime_s = int(now - stats.get('start_time', now))
    h, rem = divmod(uptime_s, 3600)
    m, s = divmod(rem, 60)
    if h > 0:
        print(f'Uptime: {h}h {m}m')
    elif m > 0:
        print(f'Uptime: {m}m {s}s')
    else:
        print(f'Uptime: {s}s')
    print(f'Triggers: {stats.get(\"triggers\", 0)}')
    print(f'Cycles: {stats.get(\"cycles\", 0)}')
    cycles = stats.get('cycles', 0)
    if cycles > 0:
        rate = cycles / max(uptime_s, 1)
        print(f'Rate: {rate:.1f} cycles/sec')
except Exception as e:
    print(f'Stats error: {e}')
" 2>/dev/null
        fi

        # Show config
        echo ""
        echo "Config:"
        if [ -f "$CONFIG_FILE" ]; then
            # Extract key settings
            THRESHOLD=$(grep -E '^THRESHOLD=' "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2 | cut -d'#' -f1 | tr -d ' ')
            COOLDOWN=$(grep -E '^COOLDOWN=' "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2 | cut -d'#' -f1 | tr -d ' ')
            CONSECUTIVE=$(grep -E '^REQUIRED_CONSECUTIVE=' "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2 | cut -d'#' -f1 | tr -d ' ')
            QS=$(grep -E '^QUIET_HOURS_START=' "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2 | cut -d'#' -f1 | tr -d ' ')
            QE=$(grep -E '^QUIET_HOURS_END=' "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2 | cut -d'#' -f1 | tr -d ' ')
            echo "  Threshold: ${THRESHOLD:-0.5}"
            echo "  Cooldown: ${COOLDOWN:-5}s"
            echo "  Required consecutive: ${CONSECUTIVE:-2}"
            echo "  Quiet hours: ${QS:-0}:00-${QE:-6}:00"
        else
            echo "  (defaults — no config file)"
        fi

        # Show latest log tail
        echo ""
        LATEST_LOG=$(ls -t "$LOG_DIR"/hey-nothing-*.log 2>/dev/null | head -1)
        if [ -n "$LATEST_LOG" ]; then
            echo "Log: $LATEST_LOG"
            echo "--- last 5 lines ---"
            tail -5 "$LATEST_LOG"
        fi
    else
        echo "Status: Not running"
    fi
}

case "${1:-}" in
    start)   do_start ;;
    stop)    do_stop ;;
    status)  do_status ;;
    restart) do_stop; sleep 1; do_start ;;
    *)
        echo "Usage: hey-nothing-ctl {start|stop|status|restart}"
        exit 1
        ;;
esac
