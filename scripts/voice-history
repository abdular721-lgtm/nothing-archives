#!/data/data/com.termux/files/usr/bin/env python3
"""
voice-history — Voice command history and analytics.

Usage:
  voice-history "what did I do today"
  voice-history "most used command"
  voice-history "how many commands today"
  voice-history "history this week"
  voice-history "what did I ask about [topic]"
"""
import json
import os
import subprocess
import sys
import urllib.request
import urllib.error
from collections import Counter
from datetime import datetime, timedelta
from pathlib import Path

HISTORY_FILE = Path.home() / "logs" / "command-history.log"
API_KEY_FILE = Path.home() / ".anthropic_key"

def say(text):
    print(text, flush=True)
    subprocess.Popen(
        ["termux-tts-speak", text],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )

def get_api_key():
    try:
        return API_KEY_FILE.read_text().strip()
    except Exception:
        return None

def call_claude(prompt, max_tokens=256):
    api_key = get_api_key()
    if not api_key:
        return None
    payload = json.dumps({
        "model": "claude-haiku-4-5-20251001",
        "max_tokens": max_tokens,
        "messages": [{"role": "user", "content": prompt}],
    }).encode()
    req = urllib.request.Request(
        "https://api.anthropic.com/v1/messages",
        data=payload,
        headers={
            "x-api-key": api_key,
            "anthropic-version": "2023-06-01",
            "content-type": "application/json",
        },
    )
    try:
        resp = urllib.request.urlopen(req, timeout=30)
        data = json.loads(resp.read())
        return data["content"][0]["text"]
    except Exception:
        return None

def load_history(days=None):
    """Load command history, optionally filtered by days."""
    if not HISTORY_FILE.exists():
        return []

    entries = []
    cutoff = None
    if days is not None:
        cutoff = datetime.now() - timedelta(days=days)

    for line in HISTORY_FILE.read_text().strip().split("\n"):
        if not line.strip():
            continue
        parts = line.split("|", 3)
        if len(parts) < 4:
            continue
        try:
            ts = int(parts[0])
            dt = datetime.fromtimestamp(ts)
            if cutoff and dt < cutoff:
                continue
            entries.append({
                "timestamp": ts,
                "datetime": parts[1],
                "command": parts[2],
                "routed_to": parts[3],
            })
        except (ValueError, OSError):
            continue

    return entries

def today_history():
    """What did I do today?"""
    entries = load_history(days=0)
    # Filter to actual today
    today_str = datetime.now().strftime("%Y-%m-%d")
    entries = [e for e in entries if today_str in e["datetime"]]

    if not entries:
        say("No voice commands recorded today.")
        return

    say(f"You used {len(entries)} voice command{'s' if len(entries) != 1 else ''} today.")
    # Read last 10
    for e in entries[-10:]:
        time_part = e["datetime"].split(" ")[-1] if " " in e["datetime"] else e["datetime"]
        say(f"At {time_part}: {e['command']}")

def most_used():
    """Most used commands."""
    entries = load_history(days=7)
    if not entries:
        say("No command history available.")
        return

    routes = Counter(e["routed_to"] for e in entries)
    top = routes.most_common(5)

    say(f"Your top commands this week:")
    for route, count in top:
        say(f"{route}: {count} time{'s' if count != 1 else ''}")

def count_today():
    """How many commands today?"""
    today_str = datetime.now().strftime("%Y-%m-%d")
    entries = [e for e in load_history(days=0) if today_str in e["datetime"]]
    say(f"You've used {len(entries)} voice command{'s' if len(entries) != 1 else ''} today.")

def week_summary():
    """Claude summarises this week's usage."""
    entries = load_history(days=7)
    if not entries:
        say("No command history this week.")
        return

    # Build summary for Claude
    lines = [f"{e['datetime']}: {e['command']} → {e['routed_to']}" for e in entries[-50:]]
    text = "\n".join(lines)

    say("Analysing your usage patterns...")
    result = call_claude(
        f"Summarise this person's voice assistant usage from the past week in 3 sentences. "
        f"What do they use most? Any interesting patterns? Be conversational.\n\n{text}",
    )
    if result:
        say(result)
    else:
        say(f"You used {len(entries)} commands this week across {len(set(e['routed_to'] for e in entries))} different features.")

def search_history(query):
    """Search history for a topic."""
    entries = load_history(days=30)
    matches = [e for e in entries if query.lower() in e["command"].lower()]

    if matches:
        say(f"Found {len(matches)} command{'s' if len(matches) != 1 else ''} about {query}.")
        for e in matches[-5:]:
            say(f"{e['datetime']}: {e['command']}")
    else:
        say(f"No commands found about {query}.")

def handle_query(text):
    t = text.lower().strip()

    if "today" in t and ("what" in t or "did" in t or "history" in t):
        today_history()
        return

    if "most used" in t or "top" in t or "popular" in t:
        most_used()
        return

    if "how many" in t or "count" in t:
        count_today()
        return

    if "week" in t or "summary" in t or "analytics" in t:
        week_summary()
        return

    if "yesterday" in t:
        yesterday_str = (datetime.now() - timedelta(days=1)).strftime("%Y-%m-%d")
        entries = [e for e in load_history(days=1) if yesterday_str in e["datetime"]]
        if entries:
            say(f"Yesterday you used {len(entries)} commands.")
            for e in entries[-10:]:
                say(f"{e['command']}")
        else:
            say("No commands recorded yesterday.")
        return

    # Search for topic
    query = t
    for prefix in ["what did i ask about ", "search history for ", "search for ", "search ", "about "]:
        if t.startswith(prefix):
            query = t[len(prefix):].strip()
            break

    search_history(query)

if __name__ == "__main__":
    if len(sys.argv) > 1:
        query = " ".join(sys.argv[1:])
    else:
        query = "what did I do today"
    handle_query(query)
