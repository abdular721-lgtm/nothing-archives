#!/data/data/com.termux/files/usr/bin/env python3
"""
voice-settings — Voice-controlled assistant settings.

Usage:
  voice-settings "open settings"          — list categories
  voice-settings "change threshold"       — adjust wake word threshold
  voice-settings "quiet hours"            — set quiet hours
  voice-settings "change stt model"       — switch STT model
  voice-settings "brief responses"        — set response length
  voice-settings "medical mode on"        — toggle clinical prompts
  voice-settings "toggle shift alerts"    — on/off shift notifications
"""
import json
import os
import subprocess
import sys
from pathlib import Path

SETTINGS_FILE = Path.home() / ".assistant-settings.json"
HEY_NOTHING_CONFIG = Path.home() / ".hey-nothing-config"

DEFAULT_SETTINGS = {
    "wake_word": {
        "threshold": 0.3,
        "required_consecutive": 2,
        "quiet_hours_start": 0,
        "quiet_hours_end": 6,
    },
    "voice": {
        "stt_model": "base",
        "tts_rate": 1.0,
        "listen_duration_default": 7,
    },
    "notifications": {
        "shift_alerts": True,
        "location_automation": True,
        "proactive_suggestions": True,
        "battery_alerts": True,
    },
    "assistant": {
        "tone": "casual",
        "response_length": "brief",
        "medical_mode": True,
        "language": "en",
    },
    "location": {
        "home_wifi": "",
        "hospital_wifi": "",
        "enabled": True,
    },
}

def say(text):
    print(text, flush=True)
    subprocess.Popen(
        ["termux-tts-speak", text],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )

def listen(duration=5):
    """Listen for a voice response."""
    try:
        result = subprocess.run(
            [os.path.expanduser("~/bin/whisper-listen"), str(duration)],
            capture_output=True, text=True, timeout=duration + 10,
        )
        return result.stdout.strip()
    except Exception:
        return ""

def load_settings():
    if SETTINGS_FILE.exists():
        try:
            data = json.loads(SETTINGS_FILE.read_text())
            # Deep merge defaults
            for cat, defaults in DEFAULT_SETTINGS.items():
                if cat not in data:
                    data[cat] = defaults
                elif isinstance(defaults, dict):
                    for k, v in defaults.items():
                        data[cat].setdefault(k, v)
            return data
        except Exception:
            pass
    return json.loads(json.dumps(DEFAULT_SETTINGS))

def save_settings(settings):
    SETTINGS_FILE.write_text(json.dumps(settings, indent=2))
    # Sync relevant settings to hey-nothing config
    sync_hey_nothing_config(settings)

def sync_hey_nothing_config(settings):
    """Write wake word settings to ~/.hey-nothing-config format."""
    ww = settings.get("wake_word", {})
    lines = [
        f"THRESHOLD={ww.get('threshold', 0.3)}",
        f"COOLDOWN=5",
        f"REQUIRED_CONSECUTIVE={ww.get('required_consecutive', 2)}",
        f"QUIET_HOURS_START={ww.get('quiet_hours_start', 0)}",
        f"QUIET_HOURS_END={ww.get('quiet_hours_end', 6)}",
    ]
    HEY_NOTHING_CONFIG.write_text("\n".join(lines) + "\n")

def show_categories():
    say("Settings categories: wake word, voice, notifications, assistant, and location. What would you like to change?")

def change_threshold():
    settings = load_settings()
    current = settings["wake_word"]["threshold"]
    say(f"Wake word threshold is currently {current}. Say a number between 0.1 and 0.9. Lower is more sensitive.")
    response = listen(5)
    try:
        # Extract number from response
        import re
        nums = re.findall(r'[\d.]+', response)
        if nums:
            val = float(nums[0])
            if 0.05 <= val <= 0.95:
                settings["wake_word"]["threshold"] = round(val, 2)
                save_settings(settings)
                say(f"Threshold changed to {val}. Restart the wake word daemon for this to take effect.")
                return
    except Exception:
        pass
    say("I couldn't understand the value. Threshold unchanged.")

def change_quiet_hours():
    settings = load_settings()
    start = settings["wake_word"]["quiet_hours_start"]
    end = settings["wake_word"]["quiet_hours_end"]
    say(f"Quiet hours are currently {start} to {end}. Say the start hour, like midnight or 11 PM.")
    response = listen(5)
    import re
    nums = re.findall(r'\d+', response)
    if nums:
        new_start = int(nums[0])
        if 0 <= new_start <= 23:
            settings["wake_word"]["quiet_hours_start"] = new_start
            say(f"Start set to {new_start}. Now say the end hour.")
            response = listen(5)
            nums = re.findall(r'\d+', response)
            if nums:
                new_end = int(nums[0])
                if 0 <= new_end <= 23:
                    settings["wake_word"]["quiet_hours_end"] = new_end
                    save_settings(settings)
                    say(f"Quiet hours set to {new_start} to {new_end}.")
                    return
    say("Couldn't update quiet hours.")

def change_stt_model():
    settings = load_settings()
    current = settings["voice"]["stt_model"]
    say(f"STT model is currently {current}. Options: fast for tiny, balanced for base, or accurate for small.")
    response = listen(5).lower()
    model_map = {"fast": "tiny", "tiny": "tiny", "balanced": "base", "base": "base", "accurate": "small", "small": "small"}
    for key, val in model_map.items():
        if key in response:
            settings["voice"]["stt_model"] = val
            save_settings(settings)
            say(f"STT model changed to {val}.")
            return
    say("Couldn't understand. Model unchanged.")

def change_response_length():
    settings = load_settings()
    current = settings["assistant"]["response_length"]
    if "brief" in current:
        settings["assistant"]["response_length"] = "detailed"
        save_settings(settings)
        say("Response length set to detailed.")
    else:
        settings["assistant"]["response_length"] = "brief"
        save_settings(settings)
        say("Response length set to brief.")

def toggle_medical_mode():
    settings = load_settings()
    current = settings["assistant"]["medical_mode"]
    settings["assistant"]["medical_mode"] = not current
    save_settings(settings)
    state = "on" if settings["assistant"]["medical_mode"] else "off"
    say(f"Medical mode is now {state}.")

def toggle_shift_alerts():
    settings = load_settings()
    current = settings["notifications"]["shift_alerts"]
    settings["notifications"]["shift_alerts"] = not current
    save_settings(settings)
    state = "on" if settings["notifications"]["shift_alerts"] else "off"
    say(f"Shift alerts are now {state}.")

def toggle_location():
    settings = load_settings()
    current = settings["notifications"]["location_automation"]
    settings["notifications"]["location_automation"] = not current
    save_settings(settings)
    state = "on" if settings["notifications"]["location_automation"] else "off"
    say(f"Location automation is now {state}.")

def change_tone():
    settings = load_settings()
    current = settings["assistant"]["tone"]
    if current == "casual":
        settings["assistant"]["tone"] = "formal"
        save_settings(settings)
        say("Tone set to formal.")
    else:
        settings["assistant"]["tone"] = "casual"
        save_settings(settings)
        say("Tone set to casual.")

def show_current():
    settings = load_settings()
    ww = settings["wake_word"]
    voice = settings["voice"]
    asst = settings["assistant"]
    notif = settings["notifications"]
    say(
        f"Wake word threshold {ww['threshold']}, quiet hours {ww['quiet_hours_start']} to {ww['quiet_hours_end']}. "
        f"STT model {voice['stt_model']}. "
        f"Tone {asst['tone']}, responses {asst['response_length']}, medical mode {'on' if asst['medical_mode'] else 'off'}. "
        f"Shift alerts {'on' if notif['shift_alerts'] else 'off'}, location {'on' if notif['location_automation'] else 'off'}."
    )

def handle_query(text):
    t = text.lower().strip()

    if "threshold" in t or "sensitivity" in t:
        change_threshold()
        return
    if "quiet hour" in t:
        change_quiet_hours()
        return
    if "stt" in t or "model" in t or "transcription" in t:
        change_stt_model()
        return
    if "brief" in t or "detailed" in t or "response length" in t:
        change_response_length()
        return
    if "medical" in t or "clinical" in t:
        toggle_medical_mode()
        return
    if "shift alert" in t:
        toggle_shift_alerts()
        return
    if "location" in t and ("toggle" in t or "on" in t or "off" in t):
        toggle_location()
        return
    if "formal" in t or "casual" in t or "tone" in t:
        change_tone()
        return
    if "current" in t or "show" in t or "status" in t or "all" in t:
        show_current()
        return

    show_categories()

if __name__ == "__main__":
    if len(sys.argv) > 1:
        query = " ".join(sys.argv[1:])
    else:
        query = "open settings"

    # Ensure settings file exists with defaults
    if not SETTINGS_FILE.exists():
        SETTINGS_FILE.write_text(json.dumps(DEFAULT_SETTINGS, indent=2))

    handle_query(query)
