#!/data/data/com.termux/files/usr/bin/env python3
"""
voice-note-ai — Claude-powered note search and summarisation
Extends the existing ~/notes/ system with AI capabilities.

Usage:
  voice-note-ai "summarise my notes this week"
  voice-note-ai "what did I note about grocery"
  voice-note-ai "read my last note"
  voice-note-ai "how many notes"
  voice-note-ai "delete note about [topic]"
"""
import json
import os
import subprocess
import sys
import urllib.request
import urllib.error
from datetime import datetime, timedelta
from pathlib import Path

NOTES_DIR = Path.home() / "notes"
API_KEY_FILE = Path.home() / ".anthropic_key"

def say(text):
    print(text, flush=True)
    subprocess.Popen(
        ["termux-tts-speak", text],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )

def get_api_key():
    try:
        return API_KEY_FILE.read_text().strip()
    except Exception:
        return None

def call_claude(prompt, max_tokens=512):
    api_key = get_api_key()
    if not api_key:
        return None
    payload = json.dumps({
        "model": "claude-haiku-4-5-20251001",
        "max_tokens": max_tokens,
        "messages": [{"role": "user", "content": prompt}],
    }).encode()
    req = urllib.request.Request(
        "https://api.anthropic.com/v1/messages",
        data=payload,
        headers={
            "x-api-key": api_key,
            "anthropic-version": "2023-06-01",
            "content-type": "application/json",
        },
    )
    try:
        resp = urllib.request.urlopen(req, timeout=30)
        data = json.loads(resp.read())
        return data["content"][0]["text"]
    except Exception as e:
        print(f"Claude API error: {e}")
        return None

def get_notes(days=None):
    """Get note files, optionally filtered by recency."""
    if not NOTES_DIR.exists():
        return []
    notes = sorted(NOTES_DIR.glob("*.md"), key=lambda p: p.stat().st_mtime, reverse=True)
    if days is not None:
        cutoff = datetime.now() - timedelta(days=days)
        notes = [n for n in notes if datetime.fromtimestamp(n.stat().st_mtime) >= cutoff]
    return notes

def summarise_week():
    """Summarise notes from the past 7 days."""
    notes = get_notes(days=7)
    if not notes:
        say("No notes from the past week.")
        return

    contents = []
    for n in notes:
        contents.append(f"=== {n.stem} ===\n{n.read_text().strip()}")

    combined = "\n\n".join(contents)
    if len(combined) > 8000:
        combined = combined[:8000] + "\n[truncated]"

    say(f"Analysing {len(notes)} notes from this week...")
    result = call_claude(
        f"Summarise these voice notes from the past week in 3-4 sentences. "
        f"Highlight key topics, action items, and anything important.\n\n{combined}",
        max_tokens=256,
    )
    if result:
        say(result)
    else:
        say("Couldn't generate summary. Check your internet connection.")

def search_notes(query):
    """Search notes by keyword — grep first, Claude fallback for semantic search."""
    if not query:
        say("What should I search for?")
        return

    notes = get_notes()
    if not notes:
        say("You don't have any notes yet.")
        return

    # Fast grep search
    matches = []
    for n in notes:
        content = n.read_text()
        if query.lower() in content.lower():
            # Extract relevant lines
            lines = content.split("\n")
            relevant = [l.strip() for l in lines if query.lower() in l.lower()]
            matches.append((n.stem, relevant[:3]))

    if matches:
        say(f"Found {query} in {len(matches)} note{'s' if len(matches) != 1 else ''}.")
        for name, lines in matches[:3]:
            text = ". ".join(lines)[:200]
            say(f"In {name}: {text}")
        return

    # Semantic search via Claude
    say(f"No exact match for {query}. Searching with AI...")
    contents = []
    for n in notes[:20]:  # Limit to 20 most recent
        contents.append(f"=== {n.stem} ===\n{n.read_text().strip()[:500]}")

    combined = "\n\n".join(contents)
    result = call_claude(
        f"Search these notes for anything related to '{query}'. "
        f"If you find relevant content, quote the specific note and passage. "
        f"If nothing is related, say so briefly.\n\n{combined}",
        max_tokens=256,
    )
    if result:
        say(result)
    else:
        say(f"No notes found about {query}.")

def read_last():
    """Read the most recent note."""
    notes = get_notes()
    if not notes:
        say("You don't have any notes yet.")
        return

    latest = notes[0]
    content = latest.read_text().strip()
    word_count = len(content.split())
    say(f"Your last note is {latest.stem}, {word_count} words.")
    # Read content (truncate for TTS)
    if len(content) > 500:
        say(content[:500] + "... that's the first part.")
    else:
        say(content)

def count_notes():
    """Count total notes."""
    notes = get_notes()
    say(f"You have {len(notes)} note{'s' if len(notes) != 1 else ''} in your collection.")

def delete_note(query):
    """Find and delete a note (with confirmation)."""
    if not query:
        say("Which note should I delete? Give me a topic or title.")
        return

    notes = get_notes()
    matches = [n for n in notes if query.lower() in n.stem.lower() or query.lower() in n.read_text().lower()]

    if not matches:
        say(f"No notes found matching {query}.")
        return

    target = matches[0]
    say(f"Found note: {target.stem}. Say yes to delete it.")

    try:
        result = subprocess.run(
            [os.path.expanduser("~/bin/whisper-listen"), "5"],
            capture_output=True, text=True, timeout=15,
        )
        response = result.stdout.strip().lower()
        if "yes" in response:
            target.unlink()
            say(f"Deleted {target.stem}.")
        else:
            say("Deletion cancelled.")
    except Exception:
        say("Couldn't hear your response. Deletion cancelled.")

def handle_query(text):
    t = text.lower().strip()

    # Summarise week
    if ("summar" in t or "this week" in t) and ("note" in t or "week" in t):
        summarise_week()
        return

    # Read last
    if "last" in t or "recent" in t or "latest" in t:
        read_last()
        return

    # Count
    if "how many" in t or "count" in t:
        count_notes()
        return

    # Delete
    if "delete" in t or "remove" in t:
        query = t
        for prefix in ["delete note about ", "delete note ", "remove note about ", "remove note ", "delete ", "remove "]:
            if t.startswith(prefix):
                query = t[len(prefix):].strip()
                break
        delete_note(query)
        return

    # Search (default for most queries)
    query = t
    for prefix in ["what did i note about ", "search notes for ", "search for ", "search ", "find ", "note about ", "about "]:
        if t.startswith(prefix):
            query = t[len(prefix):].strip()
            break

    if "note" in query:
        query = query.replace("notes", "").replace("note", "").strip()
    if "my" in query:
        query = query.replace("my", "").strip()

    search_notes(query)

if __name__ == "__main__":
    if len(sys.argv) > 1:
        query = " ".join(sys.argv[1:])
    else:
        say("What would you like to know about your notes?")
        try:
            result = subprocess.run(
                [os.path.expanduser("~/bin/whisper-listen"), "5"],
                capture_output=True, text=True, timeout=15,
            )
            query = result.stdout.strip()
            if not query:
                say("I didn't hear anything.")
                sys.exit(1)
        except Exception:
            say("Couldn't listen.")
            sys.exit(1)

    handle_query(query)
