#!/data/data/com.termux/files/usr/bin/bash
# Voice-search through notes, show matches

set -e

NOTES_DIR="$HOME/notes"

if [ ! -d "$NOTES_DIR" ] || [ -z "$(ls -A "$NOTES_DIR" 2>/dev/null)" ]; then
    echo "📭 No notes yet."
    exit 0
fi

# Accept pre-captured text as $1 or listen fresh
if [ -n "$1" ]; then
    QUERY=$(echo "$1" | sed -E 's/^(search|find)[[:space:]]+(note[s]?[[:space:]]+)?(for[[:space:]]+)?//i' | xargs)
    [ -z "$QUERY" ] && QUERY="$1"
else
    echo "🎤 Speak your search query (5 seconds)"
    QUERY=$(whisper-listen 5)
fi

if [ -z "$QUERY" ]; then
    echo "❌ No query captured"
    exit 1
fi

# Trim trailing punctuation from Whisper
QUERY=$(echo "$QUERY" | sed -E 's/[[:punct:]]+$//' | xargs)

echo "🔍 Searching for: $QUERY"
echo ""

MATCHES=$(grep -liE "$QUERY" "$NOTES_DIR"/*.md 2>/dev/null || true)

if [ -z "$MATCHES" ]; then
    MSG="No notes match: $QUERY"
    echo "$MSG"
    termux-toast "$MSG"
    termux-tts-speak "$MSG" 2>/dev/null &
    exit 0
fi

COUNT=$(echo "$MATCHES" | wc -l)
MSG="Found $COUNT matching notes"
echo "$MSG"
echo ""
echo "$MATCHES" | while read -r f; do
    fname=$(basename "$f")
    title=$(head -1 "$f" | sed -E 's/^#[[:space:]]+//')
    echo "── $fname ──"
    echo "Title: $title"
    grep -iE --color=never -n "$QUERY" "$f" | head -5
    echo ""
done

termux-toast "$MSG"
termux-tts-speak "$MSG" 2>/dev/null &
