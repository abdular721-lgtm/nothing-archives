#!/data/data/com.termux/files/usr/bin/bash
# Voice-controlled alarm setter (Whisper backend)
if [ "$1" = "--help" ]; then
    MSG="Voice alarm: say a time like 7am, 6:30 PM, or wake me at 8. Supports up to 3 retries."
    echo "$MSG"
    termux-tts-speak "$MSG" 2>/dev/null
    exit 0
fi

set -e

MAX_ATTEMPTS=3
attempt=1

# If pre-captured text passed as $1, use it for the first attempt
PRE_TEXT="$1"

while [ $attempt -le $MAX_ATTEMPTS ]; do
    if [ -n "$PRE_TEXT" ] && [ $attempt -eq 1 ]; then
        TEXT="$PRE_TEXT"
    else
        echo "🎤 Attempt $attempt: speak within 5 seconds"
        TEXT=$(whisper-listen 5)
    fi

    if [ -z "$TEXT" ]; then
        echo "⚠️  No speech detected"
        attempt=$((attempt + 1))
        continue
    fi

    echo "Heard: $TEXT"
    PARSED=$(python3 ~/bin/parse_alarm.py "$TEXT")

    if [ -n "$PARSED" ]; then
        HOUR=$(echo "$PARSED" | cut -d'|' -f1)
        MINUTE=$(echo "$PARSED" | cut -d'|' -f2)
        LABEL=$(echo "$PARSED" | cut -d'|' -f3)
        MIN_PADDED=$(printf '%02d' "$MINUTE")
        MSG="Alarm set for ${HOUR}:${MIN_PADDED}"
        echo "⏰ Setting alarm: ${HOUR}:${MIN_PADDED} — $LABEL"

        am start -a android.intent.action.SET_ALARM \
            --ei android.intent.extra.alarm.HOUR "$HOUR" \
            --ei android.intent.extra.alarm.MINUTES "$MINUTE" \
            --ez android.intent.extra.alarm.SKIP_UI true \
            --es android.intent.extra.alarm.MESSAGE "$LABEL" \
            > /dev/null 2>&1

        termux-toast "$MSG"
        termux-tts-speak "$MSG" 2>/dev/null &
        ~/bin/voice-context write last_action alarm
        ~/bin/voice-context write last_alarm_time "${HOUR}:${MIN_PADDED}"
        exit 0
    fi

    echo "⚠️  Could not parse time — try again"
    attempt=$((attempt + 1))
done

MSG="Failed to set alarm"
termux-toast "$MSG"
termux-tts-speak "$MSG" 2>/dev/null &
echo "❌ Gave up after $MAX_ATTEMPTS attempts"
exit 1
