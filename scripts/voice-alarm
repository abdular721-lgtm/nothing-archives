#!/data/data/com.termux/files/usr/bin/env python3
"""
voice-alarm — Intelligent alarm setter
Supports: time-based, duration-based, shift-relative, snooze, cancel, list.

Usage:
  voice-alarm "7am"
  voice-alarm "wake me in 8 hours"
  voice-alarm "alarm after my shift"
  voice-alarm "snooze 10 minutes"
  voice-alarm "cancel alarm"
  voice-alarm "what alarms do I have"
"""
import json
import os
import re
import subprocess
import sys
from datetime import datetime, timedelta
from pathlib import Path

SCHEDULE_FILE = Path.home() / ".shift-schedule.json"

def say(text):
    print(text, flush=True)
    subprocess.Popen(
        ["termux-tts-speak", text],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )

def set_alarm(hour, minute, label="Alarm"):
    """Fire Android SET_ALARM intent via su shell."""
    min_padded = f"{minute:02d}"
    subprocess.run(
        ["su", "shell", "-c",
         f'am start -a android.intent.action.SET_ALARM '
         f'--ei android.intent.extra.alarm.HOUR {hour} '
         f'--ei android.intent.extra.alarm.MINUTES {minute} '
         f'--ez android.intent.extra.alarm.SKIP_UI true '
         f'--es android.intent.extra.alarm.MESSAGE "{label}"'],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
    )
    # Update voice context
    subprocess.run([os.path.expanduser("~/bin/voice-context"), "write", "last_action", "alarm"],
                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    subprocess.run([os.path.expanduser("~/bin/voice-context"), "write", "last_alarm_time", f"{hour}:{min_padded}"],
                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    return f"{hour}:{min_padded}"

def load_shifts():
    if not SCHEDULE_FILE.exists():
        return []
    try:
        data = json.loads(SCHEDULE_FILE.read_text())
        return data.get("shifts", [])
    except Exception:
        return []

def get_current_or_next_shift_end():
    """Find the end time of current shift, or next shift if not on shift."""
    now = datetime.now()
    shifts = load_shifts()
    best = None
    for s in shifts:
        date = datetime.strptime(s["date"], "%Y-%m-%d")
        start_h, start_m = map(int, s["start"].split(":"))
        end_h, end_m = map(int, s["end"].split(":"))
        start_dt = date.replace(hour=start_h, minute=start_m)
        if end_h < start_h:
            end_dt = (date + timedelta(days=1)).replace(hour=end_h, minute=end_m)
        else:
            end_dt = date.replace(hour=end_h, minute=end_m)

        if start_dt <= now <= end_dt:
            return end_dt, s["type"]

        if start_dt > now:
            if best is None or start_dt < best[0]:
                best = (end_dt, s["type"])

    if best:
        return best
    return None, None

# ── Word-to-number conversion ──

WORD_NUMS = {
    'zero': 0, 'one': 1, 'two': 2, 'three': 3, 'four': 4, 'five': 5,
    'six': 6, 'seven': 7, 'eight': 8, 'nine': 9, 'ten': 10,
    'eleven': 11, 'twelve': 12, 'thirteen': 13, 'fourteen': 14,
    'fifteen': 15, 'sixteen': 16, 'seventeen': 17, 'eighteen': 18,
    'nineteen': 19, 'twenty': 20, 'thirty': 30, 'forty': 40, 'fifty': 50,
    'oh': 0, 'o': 0,
}

def words_to_nums(text):
    tokens = text.split()
    out = []
    i = 0
    while i < len(tokens):
        w = tokens[i]
        if w in WORD_NUMS:
            val = WORD_NUMS[w]
            if val in (20, 30, 40, 50) and i + 1 < len(tokens):
                nxt = tokens[i + 1]
                if nxt in WORD_NUMS and WORD_NUMS[nxt] < 10:
                    val += WORD_NUMS[nxt]
                    i += 1
            out.append(str(val))
        else:
            out.append(w)
        i += 1
    return " ".join(out)

# ── Handlers ──

def handle_duration(text):
    """'wake me in 8 hours', 'alarm in 30 minutes', 'sleep for 6 hours'"""
    t = words_to_nums(text)
    hours = 0
    minutes = 0

    h_match = re.search(r'(\d+)\s*hour', t)
    m_match = re.search(r'(\d+)\s*min', t)

    if h_match:
        hours = int(h_match.group(1))
    if m_match:
        minutes = int(m_match.group(1))

    if hours == 0 and minutes == 0:
        return False

    target = datetime.now() + timedelta(hours=hours, minutes=minutes)
    time_str = set_alarm(target.hour, target.minute, "Timer")

    duration_parts = []
    if hours:
        duration_parts.append(f"{hours} hour{'s' if hours != 1 else ''}")
    if minutes:
        duration_parts.append(f"{minutes} minute{'s' if minutes != 1 else ''}")
    duration_text = " and ".join(duration_parts)

    say(f"Alarm set for {time_str}, {duration_text} from now.")
    return True

def handle_shift_relative(text):
    """'alarm after my shift', 'wake me when shift ends', 'alarm before shift'"""
    if "before" in text:
        shifts = load_shifts()
        now = datetime.now()
        for s in sorted(shifts, key=lambda x: x["date"]):
            date = datetime.strptime(s["date"], "%Y-%m-%d")
            start_h, start_m = map(int, s["start"].split(":"))
            start_dt = date.replace(hour=start_h, minute=start_m)
            if start_dt > now:
                target = start_dt - timedelta(hours=1)
                time_str = set_alarm(target.hour, target.minute, f"Pre-{s['type']} shift")
                say(f"Alarm set for {time_str}, one hour before your {s['type']} shift.")
                return True
        say("No upcoming shifts found.")
        return True

    end_dt, shift_type = get_current_or_next_shift_end()
    if end_dt is None:
        say("No shifts found in your schedule.")
        return True

    target = end_dt + timedelta(minutes=30)
    time_str = set_alarm(target.hour, target.minute, f"Post-{shift_type} shift")
    say(f"Alarm set for {time_str}, 30 minutes after your {shift_type} shift ends at {end_dt.strftime('%H:%M')}.")
    return True

def handle_snooze(text):
    """'snooze', 'snooze 10 minutes'"""
    t = words_to_nums(text)
    m_match = re.search(r'(\d+)', t)
    minutes = int(m_match.group(1)) if m_match else 10

    target = datetime.now() + timedelta(minutes=minutes)
    time_str = set_alarm(target.hour, target.minute, "Snooze")
    say(f"Snoozed for {minutes} minutes. Alarm at {time_str}.")
    return True

def handle_cancel(text):
    """'cancel alarm', 'delete alarm'"""
    subprocess.run(
        ["su", "shell", "-c",
         "am start -n com.google.android.deskclock/com.android.deskclock.DeskClock"],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
    )
    say("Opening Clock app. Please dismiss your alarm there.")
    return True

def handle_list(text):
    """'what alarms do I have', 'upcoming alarms'"""
    db_paths = [
        "/data/data/com.google.android.deskclock/databases/alarms.db",
        "/data/data/com.nothing.clock/databases/alarms.db",
    ]
    for db_path in db_paths:
        try:
            result = subprocess.run(
                ["su", "-c", f'sqlite3 {db_path} "SELECT hour, minutes, enabled, label FROM alarm_instances WHERE enabled=1 ORDER BY hour, minutes"'],
                capture_output=True, text=True, timeout=5,
            )
            if result.returncode == 0 and result.stdout.strip():
                lines = result.stdout.strip().split("\n")
                alarms = []
                for line in lines:
                    parts = line.split("|")
                    if len(parts) >= 3:
                        h, m = int(parts[0]), int(parts[1])
                        label = parts[3] if len(parts) > 3 else ""
                        alarms.append(f"{h}:{m:02d} {label}".strip())
                if alarms:
                    alarm_text = ", ".join(alarms)
                    say(f"You have {len(alarms)} active alarm{'s' if len(alarms) != 1 else ''}: {alarm_text}.")
                    return True
        except Exception:
            continue

    # Fallback — check voice context
    try:
        result = subprocess.run(
            [os.path.expanduser("~/bin/voice-context"), "read", "last_alarm_time"],
            capture_output=True, text=True, timeout=3,
        )
        last = result.stdout.strip()
        if last:
            say(f"I can't read the alarm database, but your last alarm was set for {last}.")
            return True
    except Exception:
        pass

    subprocess.run(
        ["su", "shell", "-c",
         "am start -n com.google.android.deskclock/com.android.deskclock.DeskClock"],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
    )
    say("Opening Clock app to show your alarms.")
    return True

def handle_time_based(text):
    """Classic time parsing: '7am', '6:30 PM'"""
    t = text.lower().strip()
    t = re.sub(r'(\d)(am|pm|a\.m\.|p\.m\.)', r'\1 \2', t)
    t = words_to_nums(t)

    hour = None
    minute = 0

    m = re.search(r'\b(\d{1,2})[:\.](\d{1,2})\b', t)
    if m:
        h, mn = int(m.group(1)), int(m.group(2))
        if h <= 23 and mn <= 59:
            hour, minute = h, mn

    if hour is None:
        m = re.search(r'\b(\d{1,2})\b', t)
        if m:
            hour = int(m.group(1))

    if hour is None:
        return False

    if 'pm' in t or 'p.m' in t or 'evening' in t or 'afternoon' in t:
        if hour < 12:
            hour += 12
    elif 'am' in t or 'a.m' in t or 'morning' in t:
        if hour == 12:
            hour = 0

    if not (0 <= hour <= 23 and 0 <= minute <= 59):
        return False

    label = "Alarm"
    for keyword in ['medication', 'gym', 'work', 'meeting', 'wake', 'meds', 'shift']:
        if keyword in text.lower():
            label = keyword.capitalize()
            break

    time_str = set_alarm(hour, minute, label)
    say(f"Alarm set for {time_str}.")
    return True

def handle_query(text):
    t = text.lower().strip()

    if any(w in t for w in ["cancel", "delete", "stop", "remove", "clear"]) and "alarm" in t:
        return handle_cancel(t)

    if "snooze" in t:
        return handle_snooze(t)

    if any(w in t for w in ["list", "what alarm", "upcoming alarm", "show alarm", "my alarm"]):
        return handle_list(t)

    if "shift" in t and any(w in t for w in ["after", "before", "when", "end"]):
        return handle_shift_relative(t)

    if any(w in t for w in ["hour", "minute", "min"]) and any(w in t for w in ["in", "after", "for", "sleep"]):
        if handle_duration(t):
            return True

    if handle_time_based(t):
        return True

    say("I couldn't understand the alarm time. Try something like 7 AM, in 8 hours, or after my shift.")
    return False

if __name__ == "__main__":
    if len(sys.argv) > 1:
        query = " ".join(sys.argv[1:])
    else:
        say("What time should I set the alarm?")
        try:
            result = subprocess.run(
                [os.path.expanduser("~/bin/whisper-listen"), "5"],
                capture_output=True, text=True, timeout=15,
            )
            query = result.stdout.strip()
            if not query:
                say("I didn't hear anything.")
                sys.exit(1)
            print(f"Heard: {query}")
        except Exception:
            say("Couldn't listen for alarm time.")
            sys.exit(1)

    handle_query(query)
