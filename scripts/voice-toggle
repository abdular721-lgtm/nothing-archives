#!/data/data/com.termux/files/usr/bin/bash
# Voice-controlled system toggles and adjustments
# Targets: wifi, bluetooth, data, airplane, flashlight, volume, brightness, DND, dark mode
# All Android framework commands use "su shell -c" to avoid Failed transaction on Nothing OS

set -e

# Accept pre-captured text as $1 (from voice router) or listen fresh
if [ -n "$1" ]; then
    TEXT="$1"
else
    echo "🎤 Say what to toggle (e.g., 'wifi off', 'bluetooth on', 'airplane mode')"
    TEXT=$(whisper-listen 5 | tr -d '\r\n')
fi

if [ -z "$TEXT" ]; then
    echo "❌ Nothing heard"
    termux-toast "No command captured"
    exit 1
fi

echo "Heard: $TEXT"
T=$(echo "$TEXT" | tr '[:upper:]' '[:lower:]')

# Determine desired state
STATE=""
if [[ "$T" == *"off"* || "$T" == *"disable"* ]]; then
    STATE="off"
elif [[ "$T" == *"on"* || "$T" == *"enable"* ]]; then
    STATE="on"
else
    STATE="toggle"
fi

TARGET=""
MSG=""

if [[ "$T" == *"wifi"* || "$T" == *"wi-fi"* || "$T" == *"wi fi"* ]]; then
    TARGET="wifi"
    if [ "$STATE" = "toggle" ]; then
        CUR=$(su shell -c "settings get global wifi_on")
        if [ "$CUR" = "1" ]; then STATE="off"; else STATE="on"; fi
    fi
    case "$STATE" in
        on)  su shell -c "cmd -w wifi set-wifi-enabled enabled" ;;
        off) su shell -c "cmd -w wifi set-wifi-enabled disabled" ;;
    esac
    MSG="Wi-Fi turned $STATE"

elif [[ "$T" == *"bluetooth"* || "$T" == *"blue tooth"* ]]; then
    TARGET="bluetooth"
    if [ "$STATE" = "toggle" ]; then
        CUR=$(su shell -c "settings get global bluetooth_on")
        if [ "$CUR" = "1" ]; then STATE="off"; else STATE="on"; fi
    fi
    case "$STATE" in
        on)  su shell -c "cmd bluetooth_manager enable" > /dev/null ;;
        off) su shell -c "cmd bluetooth_manager disable" > /dev/null ;;
    esac
    MSG="Bluetooth turned $STATE"

elif [[ "$T" == *"mobile data"* || "$T" == *"cellular"* || "$T" == *"data"* ]]; then
    TARGET="mobile data"
    if [ "$STATE" = "toggle" ]; then
        CUR=$(su shell -c "settings get global mobile_data")
        if [ "$CUR" = "1" ]; then STATE="off"; else STATE="on"; fi
    fi
    case "$STATE" in
        on)  su shell -c "cmd phone data enable" ;;
        off) su shell -c "cmd phone data disable" ;;
    esac
    MSG="Mobile data turned $STATE"

elif [[ "$T" == *"airplane"* || "$T" == *"flight mode"* ]]; then
    TARGET="airplane mode"
    if [ "$STATE" = "toggle" ]; then
        CUR=$(su shell -c "settings get global airplane_mode_on")
        if [ "$CUR" = "1" ]; then STATE="off"; else STATE="on"; fi
    fi
    case "$STATE" in
        on)  su shell -c "cmd connectivity airplane-mode enable" ;;
        off) su shell -c "cmd connectivity airplane-mode disable" ;;
    esac
    MSG="Airplane mode turned $STATE"

elif [[ "$T" == *"flashlight"* || "$T" == *"torch"* ]]; then
    TARGET="flashlight"
    if [ "$STATE" = "on" ] || [ "$STATE" = "toggle" ]; then
        termux-torch on
        STATE="on"
    else
        termux-torch off
    fi
    MSG="Flashlight turned $STATE"

# --- Volume control ---
# cmd media_session volume: stream 3=media, 2=ring, 1=ring, 4=alarm. Range 0-15.
elif [[ "$T" == *"volume"* || "$T" == *"mute"* ]]; then
    TARGET="volume"
    # Determine which stream
    STREAM=3  # default: media
    STREAM_NAME="media"
    if [[ "$T" == *"ring"* || "$T" == *"ringer"* ]]; then
        STREAM=2; STREAM_NAME="ring"
    elif [[ "$T" == *"alarm"* ]]; then
        STREAM=4; STREAM_NAME="alarm"
    elif [[ "$T" == *"notification"* ]]; then
        STREAM=5; STREAM_NAME="notification"
    fi

    if [[ "$T" == *"mute"* || "$T" == *"silent"* ]]; then
        su shell -c "cmd media_session volume --set 0 --stream $STREAM"
        MSG="$STREAM_NAME volume muted"
    elif [[ "$T" == *"max"* || "$T" == *"full"* ]]; then
        su shell -c "cmd media_session volume --set 15 --stream $STREAM"
        MSG="$STREAM_NAME volume set to max"
    elif [[ "$T" == *"up"* || "$T" == *"raise"* || "$T" == *"higher"* || "$T" == *"increase"* ]]; then
        su shell -c "cmd media_session volume --adj raise --stream $STREAM"
        MSG="$STREAM_NAME volume up"
    elif [[ "$T" == *"down"* || "$T" == *"lower"* || "$T" == *"decrease"* || "$T" == *"reduce"* ]]; then
        su shell -c "cmd media_session volume --adj lower --stream $STREAM"
        MSG="$STREAM_NAME volume down"
    elif [[ "$T" =~ ([0-9]+) ]]; then
        # Extract number — interpret as 0-15 scale directly
        VOL="${BASH_REMATCH[1]}"
        [ "$VOL" -gt 15 ] && VOL=15
        su shell -c "cmd media_session volume --set $VOL --stream $STREAM"
        MSG="$STREAM_NAME volume set to $VOL"
    else
        # Default: just bump up
        su shell -c "cmd media_session volume --adj raise --stream $STREAM"
        MSG="$STREAM_NAME volume up"
    fi

# --- Brightness control ---
# settings put system screen_brightness: 0-255. Mode 0=manual, 1=auto.
elif [[ "$T" == *"brightness"* || "$T" == *"screen"* && ( "$T" == *"bright"* || "$T" == *"dim"* ) ]]; then
    TARGET="brightness"
    if [[ "$T" == *"auto"* ]]; then
        if [ "$STATE" = "off" ]; then
            su shell -c "settings put system screen_brightness_mode 0"
            MSG="Auto brightness off"
        else
            su shell -c "settings put system screen_brightness_mode 1"
            MSG="Auto brightness on"
        fi
    else
        # Switch to manual mode for manual adjustments
        su shell -c "settings put system screen_brightness_mode 0"
        CUR=$(su shell -c "settings get system screen_brightness")

        if [[ "$T" == *"max"* || "$T" == *"full"* ]]; then
            su shell -c "settings put system screen_brightness 255"
            MSG="Brightness set to maximum"
        elif [[ "$T" == *"min"* || "$T" == *"low"* || "$T" == *"dim"* ]]; then
            su shell -c "settings put system screen_brightness 10"
            MSG="Brightness set to minimum"
        elif [[ "$T" == *"up"* || "$T" == *"raise"* || "$T" == *"higher"* || "$T" == *"increase"* ]]; then
            NEW=$((CUR + 50))
            [ "$NEW" -gt 255 ] && NEW=255
            su shell -c "settings put system screen_brightness $NEW"
            PCT=$((NEW * 100 / 255))
            MSG="Brightness up to ${PCT}%"
        elif [[ "$T" == *"down"* || "$T" == *"lower"* || "$T" == *"decrease"* || "$T" == *"reduce"* ]]; then
            NEW=$((CUR - 50))
            [ "$NEW" -lt 5 ] && NEW=5
            su shell -c "settings put system screen_brightness $NEW"
            PCT=$((NEW * 100 / 255))
            MSG="Brightness down to ${PCT}%"
        elif [[ "$T" =~ ([0-9]+)[[:space:]]*percent ]]; then
            PCT="${BASH_REMATCH[1]}"
            VAL=$((PCT * 255 / 100))
            [ "$VAL" -gt 255 ] && VAL=255
            [ "$VAL" -lt 1 ] && VAL=1
            su shell -c "settings put system screen_brightness $VAL"
            MSG="Brightness set to ${PCT}%"
        else
            # Default: bump up
            NEW=$((CUR + 50))
            [ "$NEW" -gt 255 ] && NEW=255
            su shell -c "settings put system screen_brightness $NEW"
            PCT=$((NEW * 100 / 255))
            MSG="Brightness set to ${PCT}%"
        fi
    fi

# --- Do Not Disturb ---
# cmd notification set_dnd on/off
elif [[ "$T" == *"do not disturb"* || "$T" == *"dnd"* || "$T" == *"silent mode"* ]]; then
    TARGET="do not disturb"
    if [ "$STATE" = "toggle" ]; then
        CUR=$(su shell -c "settings get global zen_mode")
        if [ "$CUR" = "0" ]; then STATE="on"; else STATE="off"; fi
    fi
    case "$STATE" in
        on)  su shell -c "cmd notification set_dnd on" ;;
        off) su shell -c "cmd notification set_dnd off" ;;
    esac
    MSG="Do not disturb turned $STATE"

# --- Dark mode ---
# cmd uimode night yes/no
elif [[ "$T" == *"dark mode"* || "$T" == *"night mode"* || "$T" == *"light mode"* ]]; then
    TARGET="dark mode"
    # "light mode" means dark mode off
    if [[ "$T" == *"light mode"* ]]; then
        STATE="off"
    elif [ "$STATE" = "toggle" ]; then
        CUR=$(su shell -c "settings get secure ui_night_mode")
        if [ "$CUR" = "2" ]; then STATE="off"; else STATE="on"; fi
    fi
    case "$STATE" in
        on)  su shell -c "cmd uimode night yes" > /dev/null ;;
        off) su shell -c "cmd uimode night no" > /dev/null ;;
    esac
    MSG="Dark mode turned $STATE"

else
    MSG="Unknown toggle: $TEXT"
    echo "⚠️  No matching toggle. Try: wifi, bluetooth, data, airplane, flashlight, volume, brightness, dnd, dark mode"
    termux-toast "$MSG"
    termux-tts-speak "$MSG" 2>/dev/null &
    exit 1
fi

echo "✅ $MSG"
termux-toast "$MSG"
termux-tts-speak "$MSG" 2>/dev/null &
