#!/data/data/com.termux/files/usr/bin/bash
# Hey Nothing — wake word detection daemon (whisper polling)
# Continuously records short clips, transcribes with whisper tiny.en,
# and triggers ~/bin/voice when "hey nothing" is detected.
#
# Usage: hey-nothing              (run in foreground)
#        hey-nothing --daemon      (internal: set by hey-nothing-ctl)
#
# Cycle time: ~7.5s (2s record + 2.3s wait + 0.6s convert + 2.9s whisper + ~0.7s gap).
# Adjust POLL_INTERVAL below to trade responsiveness for battery.

# No set -e — daemon must survive individual cycle failures

# ─── Config defaults ─────────────────────────────────────
LISTEN_DURATION=2        # seconds to record each cycle
POLL_INTERVAL=1          # seconds to sleep between cycles (low = responsive, high = battery saver)
POLL_INTERVAL_SCREEN_OFF=8  # seconds between cycles when screen is off
COOLDOWN=15              # seconds to wait after triggering voice router
MAX_ERRORS=10            # consecutive errors before backing off
ERROR_BACKOFF=30         # seconds to sleep after MAX_ERRORS consecutive failures
ENERGY_THRESHOLD=500     # RMS threshold — below this = silence, skip whisper
SCREEN_AWARE=true        # adapt poll interval based on screen state
QUIET_HOURS_START=0      # hour (24h) to start quiet mode
QUIET_HOURS_END=6        # hour (24h) to end quiet mode
QUIET_POLL_INTERVAL=30   # seconds between cycles during quiet hours
PID_FILE="$HOME/.hey-nothing.pid"
LOG_DIR="$HOME/logs"
STATS_FILE="$HOME/.hey-nothing-stats"
CONFIG_FILE="$HOME/.hey-nothing-config"

# ─── Load config file (overrides defaults) ───────────────
if [ -f "$CONFIG_FILE" ]; then
    . "$CONFIG_FILE"
fi
# Single-word triggers (matched as whole words or entire utterance)
SINGLE_TRIGGERS="nothing|assistant|computer"
# Multi-word triggers (matched as phrase anywhere in text)
MULTI_TRIGGERS="hey nothing|a nothing|hey nah thing|hey nan thing|nothing phone|hey nasim|hey assistant|okay nothing|ok nothing|yo nothing|hello nothing|hi nothing|hey phone"
# Max words for a valid wake command (longer = ambient speech, not a wake word)
MAX_WAKE_WORDS=6

mkdir -p "$LOG_DIR"

# ─── Signal handling ──────────────────────────────────────
cleanup() {
    echo "$(date '+%H:%M:%S') Daemon stopping (signal received)"
    rm -f "$PID_FILE"
    exit 0
}
trap cleanup SIGTERM SIGINT SIGHUP

# ─── Write PID ────────────────────────────────────────────
echo $$ > "$PID_FILE"

# ─── Stats tracking ──────────────────────────────────────
STARTED_AT=$(date +%s)
DETECTIONS=0
CYCLES=0
SKIPPED_AMBIENT=0
SKIPPED_ENERGY=0
EMPTY_CYCLES=0

save_stats() {
    cat > "$STATS_FILE" <<STATS
started=$STARTED_AT
detections=$DETECTIONS
cycles=$CYCLES
skipped_ambient=$SKIPPED_AMBIENT
skipped_energy=$SKIPPED_ENERGY
empty_cycles=$EMPTY_CYCLES
last_cycle=$(date +%s)
STATS
}

# ─── Screen state check ──────────────────────────────────
is_screen_on() {
    su shell -c 'dumpsys power' 2>/dev/null | grep -q 'mWakefulness=Awake'
}

# ─── Quiet hours check ──────────────────────────────────
is_quiet_hours() {
    local HOUR
    HOUR=$(date +%H | sed 's/^0//')
    if [ "$QUIET_HOURS_START" -le "$QUIET_HOURS_END" ]; then
        # Simple range: e.g. 0-6
        [ "$HOUR" -ge "$QUIET_HOURS_START" ] && [ "$HOUR" -lt "$QUIET_HOURS_END" ]
    else
        # Wrap-around: e.g. 23-6
        [ "$HOUR" -ge "$QUIET_HOURS_START" ] || [ "$HOUR" -lt "$QUIET_HOURS_END" ]
    fi
}

# ─── Dynamic poll interval ──────────────────────────────
get_poll_interval() {
    # Quiet hours takes priority
    if is_quiet_hours; then
        echo "$QUIET_POLL_INTERVAL"
        return
    fi
    # Screen-aware polling
    if [ "$SCREEN_AWARE" = "true" ] && ! is_screen_on; then
        echo "$POLL_INTERVAL_SCREEN_OFF"
        return
    fi
    echo "$POLL_INTERVAL"
}

# ─── Acknowledgement sound ───────────────────────────────
ack() {
    # Short beep via TTS — fast feedback that wake word was heard
    termux-tts-speak "Yes?" 2>/dev/null &
    ACK_PID=$!
    # Don't let TTS block the main flow for more than 3 seconds
    ( sleep 3; kill $ACK_PID 2>/dev/null ) &
    wait $ACK_PID 2>/dev/null || true
}

# ─── Main loop ────────────────────────────────────────────
echo "$(date '+%H:%M:%S') Hey Nothing daemon started (PID $$)"
echo "  Listen: ${LISTEN_DURATION}s | Poll: ${POLL_INTERVAL}s (screen-off: ${POLL_INTERVAL_SCREEN_OFF}s) | Cooldown: ${COOLDOWN}s"
echo "  Energy gate: RMS < $ENERGY_THRESHOLD = skip whisper | Screen-aware: $SCREEN_AWARE"
echo "  Quiet hours: ${QUIET_HOURS_START}:00-${QUIET_HOURS_END}:00 (poll: ${QUIET_POLL_INTERVAL}s)"
echo "  Multi-triggers: $MULTI_TRIGGERS"
echo "  Single-triggers: $SINGLE_TRIGGERS (at start or entire utterance)"
echo "  Max wake words: $MAX_WAKE_WORDS"
echo ""

CONSECUTIVE_ERRORS=0

while true; do
    CYCLES=$((CYCLES + 1))

    # Record and transcribe with tiny.en (fastest model)
    # Energy gate skips whisper if audio is silence — saves ~3s per quiet cycle
    HEARD=$( ~/bin/whisper-listen --fast --energy-gate "$ENERGY_THRESHOLD" "$LISTEN_DURATION" 2>/dev/null | tr -d '\r\n' ) || true
    HEARD_LOWER=$(echo "$HEARD" | tr '[:upper:]' '[:lower:]')

    # Strip whisper hallucination tags that leak through
    HEARD_LOWER=$(echo "$HEARD_LOWER" | sed -E 's/\[([^]]*)\]//g' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

    # Log first 5 cycles and then every 50th for debugging
    if [ "$CYCLES" -le 5 ] || [ $((CYCLES % 50)) -eq 0 ]; then
        echo "$(date '+%H:%M:%S') Cycle $CYCLES | heard: '${HEARD_LOWER:-(silence)}'"
    fi

    # Check for wake phrase
    DETECTED=0
    if [ -n "$HEARD_LOWER" ] && [ ${#HEARD_LOWER} -gt 1 ]; then
        CONSECUTIVE_ERRORS=0  # got audio — reset error counter

        # Count words
        read -ra WORDS <<< "$HEARD_LOWER"
        WORD_COUNT=${#WORDS[@]}

        # Skip ambient speech (too many words = someone talking, not a wake command)
        if [ "$WORD_COUNT" -gt "$MAX_WAKE_WORDS" ]; then
            SKIPPED_AMBIENT=$((SKIPPED_AMBIENT + 1))
            if [ "$CYCLES" -le 5 ] || [ $((CYCLES % 50)) -eq 0 ]; then
                echo "$(date '+%H:%M:%S')   skipped: ambient speech ($WORD_COUNT words)"
            fi
        else
            # Check multi-word triggers (phrase match anywhere)
            IFS='|' read -ra PHRASES <<< "$MULTI_TRIGGERS"
            for phrase in "${PHRASES[@]}"; do
                if [[ "$HEARD_LOWER" == *"$phrase"* ]]; then
                    DETECTED=1
                    break
                fi
            done

            # Check single-word triggers (must be at start or entire utterance)
            if [ "$DETECTED" -eq 0 ]; then
                FIRST_WORD="${WORDS[0]}"
                IFS='|' read -ra SINGLES <<< "$SINGLE_TRIGGERS"
                for trigger in "${SINGLES[@]}"; do
                    if [[ "$FIRST_WORD" == "$trigger" ]] || { [ "$WORD_COUNT" -eq 1 ] && [[ "$HEARD_LOWER" == "$trigger" ]]; }; then
                        DETECTED=1
                        break
                    fi
                done
            fi

            # Also check: "nothing" as standalone word in first 2 positions
            # (avoids "I have nothing to do" false positives)
            if [ "$DETECTED" -eq 0 ]; then
                for idx in 0 1; do
                    if [ "$idx" -lt "$WORD_COUNT" ] && [[ "${WORDS[$idx]}" == "nothing" ]]; then
                        DETECTED=1
                        break
                    fi
                done
            fi
        fi
    else
        # Empty result — silence (energy gated) or mic failure
        EMPTY_CYCLES=$((EMPTY_CYCLES + 1))
        SKIPPED_ENERGY=$((SKIPPED_ENERGY + 1))
        CONSECUTIVE_ERRORS=$((CONSECUTIVE_ERRORS + 1))
        if [ "$CONSECUTIVE_ERRORS" -ge "$MAX_ERRORS" ]; then
            echo "$(date '+%H:%M:%S') WARNING: $CONSECUTIVE_ERRORS consecutive empty results — backing off ${ERROR_BACKOFF}s"
            sleep "$ERROR_BACKOFF"
            CONSECUTIVE_ERRORS=0
        fi
    fi

    if [ "$DETECTED" -eq 1 ]; then
        DETECTIONS=$((DETECTIONS + 1))
        echo "$(date '+%H:%M:%S') WAKE WORD detected in: '$HEARD' (detection #$DETECTIONS)"
        save_stats

        # Acknowledge
        ack

        # Run the voice router (blocking — waits for command to complete)
        echo "$(date '+%H:%M:%S') Launching voice router..."
        ~/bin/voice 2>&1 || true
        echo "$(date '+%H:%M:%S') Voice router finished. Cooldown ${COOLDOWN}s..."

        # Cooldown — avoid retriggering on tail-end audio
        sleep "$COOLDOWN"
    else
        # Periodic stats save every 50 cycles
        if [ $((CYCLES % 50)) -eq 0 ]; then
            save_stats
        fi
        # Dynamic poll interval: quiet hours > screen-off > normal
        CURRENT_INTERVAL=$(get_poll_interval)
        sleep "$CURRENT_INTERVAL"
    fi
done
