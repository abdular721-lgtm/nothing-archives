#!/data/data/com.termux/files/usr/bin/env python3
"""
Hey Nothing — openWakeWord-based wake word daemon
Uses hey_jarvis model — say "Hey Jarvis" to activate
Replaces whisper polling with continuous low-CPU detection

Cycle: ~80ms per audio chunk (1280 samples @ 16kHz)
Latency: <1s from wake word to acknowledgement
"""
import warnings
warnings.filterwarnings('ignore')

import os
import sys
import signal
import time
import subprocess
import json
from datetime import datetime
from pathlib import Path

# ─── Paths ────────────────────────────────────────────────
HOME = Path.home()
CONFIG_FILE = HOME / '.hey-nothing-config'
LOG_FILE = HOME / 'logs' / 'hey-nothing.log'
PID_FILE = HOME / '.hey-nothing.pid'
STATS_FILE = HOME / '.hey-nothing-stats.json'

# ─── Config defaults ─────────────────────────────────────
config = {
    'THRESHOLD': 0.3,
    'COOLDOWN': 5,
    'REQUIRED_CONSECUTIVE': 2,
    'QUIET_HOURS_START': 0,
    'QUIET_HOURS_END': 6,
    'VOICE_CMD': str(HOME / 'bin' / 'voice'),
}

# Load config file if exists
if CONFIG_FILE.exists():
    for line in CONFIG_FILE.read_text().splitlines():
        line = line.strip()
        if '=' in line and not line.startswith('#'):
            k, v = line.split('=', 1)
            k = k.strip()
            # Strip inline comments (e.g. "500  # good default")
            if '#' in v:
                v = v[:v.index('#')]
            v = v.strip()
            if k in config:
                # Cast to the type of the default value
                default_type = type(config[k])
                try:
                    if default_type == float:
                        config[k] = float(v)
                    elif default_type == int:
                        config[k] = int(v)
                    else:
                        config[k] = v
                except ValueError:
                    pass

LOG_FILE.parent.mkdir(exist_ok=True)

# ─── Logging ─────────────────────────────────────────────
def log(msg):
    ts = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
    line = f"[{ts}] {msg}"
    print(line, flush=True)
    try:
        with open(LOG_FILE, 'a') as f:
            f.write(line + '\n')
    except Exception:
        pass

# ─── Quiet hours ─────────────────────────────────────────
def in_quiet_hours():
    h = datetime.now().hour
    s, e = config['QUIET_HOURS_START'], config['QUIET_HOURS_END']
    if s <= e:
        return s <= h < e
    return h >= s or h < e

# ─── Stats ───────────────────────────────────────────────
def load_stats():
    if STATS_FILE.exists():
        try:
            return json.loads(STATS_FILE.read_text())
        except Exception:
            pass
    return {'cycles': 0, 'triggers': 0, 'start_time': time.time()}

def save_stats(stats):
    try:
        STATS_FILE.write_text(json.dumps(stats))
    except Exception:
        pass

# ─── Write PID ───────────────────────────────────────────
PID_FILE.write_text(str(os.getpid()))

# ─── Signal handling ─────────────────────────────────────
def handle_signal(sig, frame):
    log("Daemon stopping (signal received)")
    PID_FILE.unlink(missing_ok=True)
    sys.exit(0)

signal.signal(signal.SIGTERM, handle_signal)
signal.signal(signal.SIGINT, handle_signal)

# ─── Import audio/ML libs ───────────────────────────────
try:
    import pyaudio
    import numpy as np
    from openwakeword.model import Model
except ImportError as e:
    log(f"FATAL: Missing dependency: {e}")
    log("Install: pkg install python-onnxruntime python-scipy portaudio && pip install pyaudio openwakeword --no-deps")
    PID_FILE.unlink(missing_ok=True)
    sys.exit(1)

# ─── Load model ─────────────────────────────────────────
log("Loading hey_jarvis model...")
try:
    model = Model(wakeword_models=["hey_jarvis"], inference_framework="onnx")
    log("Model loaded successfully.")
except Exception as e:
    log(f"FATAL: Failed to load model: {e}")
    PID_FILE.unlink(missing_ok=True)
    sys.exit(1)

# ─── Open microphone ────────────────────────────────────
pa = None
stream = None

def open_mic():
    global pa, stream
    if pa is not None:
        try:
            stream.stop_stream()
            stream.close()
            pa.terminate()
        except Exception:
            pass
    pa = pyaudio.PyAudio()
    stream = pa.open(
        rate=16000,
        channels=1,
        format=pyaudio.paInt16,
        input=True,
        frames_per_buffer=1280
    )
    return stream

try:
    stream = open_mic()
    log("Microphone opened.")
except Exception as e:
    log(f"FATAL: Cannot open microphone: {e}")
    PID_FILE.unlink(missing_ok=True)
    sys.exit(1)

# ─── Main loop ──────────────────────────────────────────
stats = load_stats()
stats['start_time'] = time.time()
last_trigger = 0
consecutive = 0
mic_errors = 0

log(f"Daemon started (PID={os.getpid()}, threshold={config['THRESHOLD']}, "
    f"cooldown={config['COOLDOWN']}s, consecutive={config['REQUIRED_CONSECUTIVE']})")
log(f"Quiet hours: {config['QUIET_HOURS_START']}:00-{config['QUIET_HOURS_END']}:00")
log("Say 'Hey Jarvis' to activate.")

try:
    while True:
        # Quiet hours — sleep instead of processing audio
        if in_quiet_hours():
            time.sleep(30)
            continue

        # Read audio chunk (80ms of audio at 16kHz)
        try:
            audio = np.frombuffer(
                stream.read(1280, exception_on_overflow=False),
                dtype=np.int16
            )
            mic_errors = 0
        except Exception as e:
            mic_errors += 1
            if mic_errors <= 3:
                log(f"Mic read error ({mic_errors}): {e}")
            if mic_errors >= 10:
                log("Too many mic errors — attempting to reopen microphone...")
                try:
                    stream = open_mic()
                    mic_errors = 0
                    log("Microphone reopened.")
                except Exception as e2:
                    log(f"Mic reopen failed: {e2} — sleeping 10s...")
                    time.sleep(10)
            else:
                time.sleep(0.1)
            continue

        # Run inference
        try:
            predictions = model.predict(audio)
            score = predictions.get('hey_jarvis', 0)
        except Exception as e:
            log(f"Inference error: {e}")
            continue

        stats['cycles'] += 1

        if score > config['THRESHOLD']:
            consecutive += 1
            now = time.time()

            if consecutive >= config['REQUIRED_CONSECUTIVE'] and (now - last_trigger) > config['COOLDOWN']:
                last_trigger = now
                consecutive = 0
                stats['triggers'] += 1
                save_stats(stats)

                log(f"WAKE WORD detected! score={score:.3f} (trigger #{stats['triggers']})")

                # Acknowledge — short TTS "Yes?"
                subprocess.Popen(
                    ['termux-tts-speak', 'Yes?'],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL
                )

                # Launch voice router via run-voice (prevents OOM on SSH)
                log("Launching voice router...")
                subprocess.Popen(
                    [os.path.expanduser('~/bin/run-voice'), os.path.expanduser('~/bin/voice')],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL
                )

                # Reset model state to clear buffered predictions from trigger audio
                model.reset()
        else:
            if consecutive > 0:
                consecutive = 0

        # Save stats every 1000 cycles (~80 seconds)
        if stats['cycles'] % 1000 == 0:
            save_stats(stats)
            log(f"Stats: {stats['cycles']} cycles, {stats['triggers']} triggers, "
                f"uptime {int(time.time() - stats['start_time'])}s")

except KeyboardInterrupt:
    log("Daemon stopping (keyboard interrupt)")
except Exception as e:
    log(f"FATAL: Unhandled error: {e}")
finally:
    try:
        stream.stop_stream()
        stream.close()
        pa.terminate()
    except Exception:
        pass
    PID_FILE.unlink(missing_ok=True)
    log("Daemon stopped. Mic released.")
