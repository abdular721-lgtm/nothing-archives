#!/data/data/com.termux/files/usr/bin/bash
# Unified voice router — listen once, route to the right sub-script
# Usage: voice (listens for 5 seconds then routes)

if [ "$1" = "--help" ]; then
    MSG="Voice router: listen once and route to alarm, music, toggle, macro, calendar, weather, SMS, WhatsApp, notes, reminders, info, briefing, call, screenshot, YouTube, or notifications."
    echo "$MSG"
    termux-tts-speak "$MSG" 2>/dev/null
    exit 0
fi

set -e

echo "🎤 Listening..."
TEXT=$(~/bin/whisper-listen 5 | tr -d '\r\n')

if [ -z "$TEXT" ]; then
    echo "⚠️  Nothing heard — retrying..."
    TEXT=$(~/bin/whisper-listen 5 | tr -d '\r\n')
fi

if [ -z "$TEXT" ]; then
    echo "❌ Nothing heard"
    termux-toast "No command captured"
    exit 1
fi

echo "Heard: $TEXT"
T=$(echo "$TEXT" | tr '[:upper:]' '[:lower:]')

# Route based on keywords — order matters (most specific first)

# ─── Macros (multi-step sequences) ────────────────────────
if [[ "$T" == *"goodnight"* || "$T" == *"good night"* || "$T" == *"sleep"* || "$T" == *"bedtime"* || "$T" == *"good morning"* || "$T" == *"commute"* || "$T" == *"going out"* || "$T" == *"leaving"* || "$T" == *"focus mode"* || "$T" == *"study mode"* || "$T" == *"work mode"* || "$T" == *"presentation"* || "$T" == *"meeting mode"* || "$T" == *"screen share"* || "$T" == *"normal mode"* || "$T" == *"reset mode"* || "$T" == *"cancel mode"* || "$T" == *"back to normal"* ]]; then
    echo "→ voice-macro"
    exec ~/bin/voice-macro "$TEXT"

# ─── Daily briefing ──────────────────────────────────────
elif [[ "$T" == *"briefing"* || "$T" == *"what did i miss"* || "$T" == *"what did I miss"* || "$T" == *"morning report"* || "$T" == *"daily report"* ]]; then
    echo "→ voice-briefing"
    exec ~/bin/voice-briefing "$TEXT"

# ─── Phone calls ─────────���────────────────────────────────
elif [[ "$T" == *"call "* || "$T" == *"phone "* || "$T" == *"ring "* || "$T" == *"dial "* || "$T" == *"hang up"* || "$T" == *"end call"* ]]; then
    echo "→ voice-call"
    exec ~/bin/voice-call "$TEXT"

# ─── SMS / RCS ────���──────────────────────────────────────
elif [[ "$T" == *"send message"* || "$T" == *"send text"* || "$T" == *"text "* || "$T" == *"sms"* || "$T" == *"read message"* || "$T" == *"latest message"* || "$T" == *"any message"* || "$T" == *"read sms"* || "$T" == *"rcs"* || "$T" == *"google message"* ]]; then
    echo "→ voice-sms"
    exec ~/bin/voice-sms "$TEXT"

# ─── Reminder ──────────���──────────────────────────────────
elif [[ "$T" == *"remind"* || "$T" == *"reminder"* || "$T" == *"don't forget"* || "$T" == *"dont forget"* ]]; then
    echo "→ voice-reminder"
    exec ~/bin/voice-reminder "$TEXT"

# ─── WhatsApp reply ────────────────────────────────────────
elif [[ "$T" == *"reply"* && "$T" == *"whatsapp"* ]] || [[ "$T" == *"whatsapp reply"* ]] || [[ "$T" == *"send whatsapp"* ]] || [[ "$T" == *"whatsapp"* && "$T" == *"message"* && "$T" != *"read"* ]]; then
    echo "→ voice-whatsapp"
    exec ~/bin/voice-whatsapp "$TEXT"

# ─── Calendar ─────────────────────────────────────────────
elif [[ "$T" == *"calendar"* || "$T" == *"schedule"* || "$T" == *"agenda"* ]] || [[ "$T" == *"next"* && ( "$T" == *"meeting"* || "$T" == *"event"* || "$T" == *"appointment"* ) ]] || [[ "$T" == *"add event"* || "$T" == *"new event"* || "$T" == *"create event"* ]]; then
    echo "→ voice-calendar"
    exec ~/bin/voice-calendar "$TEXT"

# ─── Weather ───────────────────────────────────────────────
elif [[ "$T" == *"weather"* || "$T" == *"forecast"* || "$T" == *"umbrella"* || "$T" == *"temperature outside"* || "$T" == *"how hot"* || "$T" == *"how cold"* || "$T" == *"wind"* ]]; then
    echo "→ voice-weather"
    exec ~/bin/voice-weather "$TEXT"

# ─── Alarm ─────────────────────────────────────────────────
elif [[ "$T" == *"alarm"* || "$T" == *"wake me"* || "$T" == *"set alarm"* ]]; then
    echo "→ voice-alarm"
    exec ~/bin/voice-alarm "$TEXT"

elif [[ "$T" == *"youtube"* || ( "$T" == *"play"* && "$T" == *"video"* ) ]]; then
    echo "→ voice-youtube"
    exec ~/bin/voice-youtube "$TEXT"

# ─── Music control ────────────────────────────────────────
elif [[ "$T" == *"pause"* || "$T" == *"resume"* || "$T" == *"next song"* || "$T" == *"skip"* || "$T" == *"previous"* || "$T" == *"now playing"* || "$T" == *"what's playing"* || "$T" == *"what is playing"* || "$T" == *"current song"* ]] || [[ "$T" == *"play "* && "$T" != *"video"* ]] || [[ "$T" == *"put on "* || "$T" == *"listen to "* || "$T" == *"stop music"* || "$T" == *"stop playing"* ]]; then
    echo "→ voice-music"
    exec ~/bin/voice-music "$TEXT"

elif [[ "$T" == *"open"* || "$T" == *"launch"* || "$T" == *"start"* ]]; then
    echo "→ voice-open"
    exec ~/bin/voice-open "$TEXT"

elif [[ "$T" == *"screenshot"* || "$T" == *"screen shot"* || "$T" == *"capture screen"* ]]; then
    echo "→ voice-screenshot"
    exec ~/bin/voice-screenshot

elif [[ "$T" == *"wifi"* || "$T" == *"wi-fi"* || "$T" == *"bluetooth"* || "$T" == *"flashlight"* || "$T" == *"torch"* || "$T" == *"airplane"* || "$T" == *"mobile data"* || "$T" == *"cellular"* || "$T" == *"volume"* || "$T" == *"mute"* || "$T" == *"brightness"* || "$T" == *"do not disturb"* || "$T" == *"dnd"* || "$T" == *"silent mode"* || "$T" == *"dark mode"* || "$T" == *"night mode"* || "$T" == *"light mode"* ]]; then
    echo "→ voice-toggle"
    exec ~/bin/voice-toggle "$TEXT"

# ─── Smart home (after toggle to avoid catching wifi/bluetooth) ─
elif [[ "$T" == *"light"* || "$T" == *"lamp"* || "$T" == *"fan"* || "$T" == *"smart home"* || "$T" == *"heater"* ]] || [[ ( "$T" == *"turn on"* || "$T" == *"turn off"* ) && "$T" != *"wifi"* && "$T" != *"bluetooth"* && "$T" != *"data"* && "$T" != *"airplane"* && "$T" != *"flashlight"* && "$T" != *"torch"* ]]; then
    echo "→ voice-home"
    exec ~/bin/voice-home "$TEXT"

elif [[ "$T" == *"time"* || "$T" == *"date"* || "$T" == *"today"* || "$T" == *"battery"* || "$T" == *"charge"* || "$T" == *"storage"* || "$T" == *"free space"* || "$T" == *"ip"* || "$T" == *"wifi name"* || "$T" == *"connected to"* || "$T" == *"signal"* || "$T" == *"what day"* ]]; then
    echo "→ voice-info"
    exec ~/bin/voice-info "$TEXT"

elif [[ "$T" == *"read"* && "$T" == *"notif"* ]] || [[ "$T" == *"whatsapp"* && "$T" == *"read"* ]] || [[ "$T" == *"notification"* ]]; then
    echo "→ voice-read-notif"
    exec ~/bin/voice-read-notif "$TEXT"

elif [[ "$T" == *"search"* && "$T" == *"note"* ]] || [[ "$T" == *"find"* && "$T" == *"note"* ]]; then
    echo "→ voice-note-search"
    exec ~/bin/voice-note-search "$TEXT"

elif [[ "$T" == *"list"* && "$T" == *"note"* ]] || [[ "$T" == *"show"* && "$T" == *"note"* ]]; then
    echo "→ voice-note-list"
    exec ~/bin/voice-note-list

elif [[ "$T" == *"note"* || "$T" == *"remember"* || "$T" == *"write down"* ]]; then
    echo "→ voice-note"
    exec ~/bin/voice-note "$TEXT"

# ─── Context commands (repeat/again) ─────────────────────
elif [[ "$T" == *"again"* || "$T" == *"repeat"* || "$T" == *"do it again"* ]]; then
    echo "→ context: repeat last action"
    LAST_ACTION=$(~/bin/voice-context read last_action)
    case "$LAST_ACTION" in
        alarm)    exec ~/bin/voice-alarm ;;
        call)     CONTACT=$(~/bin/voice-context read last_contact); exec ~/bin/voice-call "call $CONTACT" ;;
        sms)      CONTACT=$(~/bin/voice-context read last_contact); MSG=$(~/bin/voice-context read last_message); exec ~/bin/voice-sms "text $CONTACT" ;;
        open)     APP=$(~/bin/voice-context read last_app_opened); exec ~/bin/voice-open "open $APP" ;;
        music)    QUERY=$(~/bin/voice-context read last_search); exec ~/bin/voice-music "play $QUERY" ;;
        youtube)  QUERY=$(~/bin/voice-context read last_search); exec ~/bin/voice-youtube "play $QUERY" ;;
        note)     exec ~/bin/voice-note ;;
        *)        echo "No recent action to repeat"; termux-tts-speak "No recent action to repeat" 2>/dev/null; exit 1 ;;
    esac

elif [[ "$T" == *"call"* && ( "$T" == *"back"* || "$T" == *"them"* ) ]]; then
    echo "→ context: call back"
    CONTACT=$(~/bin/voice-context read last_contact)
    if [ -n "$CONTACT" ]; then
        exec ~/bin/voice-call "call $CONTACT"
    else
        echo "No recent contact"; termux-tts-speak "No recent contact to call back" 2>/dev/null; exit 1
    fi

elif [[ "$T" == *"what did"* && "$T" == *"do"* ]] || [[ "$T" == *"last action"* || "$T" == *"what was that"* ]]; then
    echo "→ context: last action"
    exec ~/bin/voice-context last

else
    # No keyword match — send to Claude API for intelligent handling
    echo "→ voice-claude (no keyword match)"
    exec ~/bin/voice-claude "$TEXT"
fi
