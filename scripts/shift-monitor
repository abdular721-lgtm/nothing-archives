#!/data/data/com.termux/files/usr/bin/env python3
"""
shift-monitor — Background shift awareness daemon
Checks every 30 minutes if a shift starts within 60 minutes.
If so: TTS alert + auto-trigger focus mode.
"""
import warnings
warnings.filterwarnings("ignore")

import json
import os
import sys
import signal
import time
import subprocess
from datetime import datetime, timedelta
from pathlib import Path

HOME = Path.home()
SCHEDULE_FILE = HOME / ".shift-schedule.json"
PID_FILE = HOME / ".shift-monitor.pid"
LOG_FILE = HOME / "logs" / "shift-monitor.log"

LOG_FILE.parent.mkdir(exist_ok=True)

def log(msg):
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    line = f"[{ts}] {msg}"
    print(line, flush=True)
    try:
        with open(LOG_FILE, "a") as f:
            f.write(line + "\n")
    except Exception:
        pass

# PID file
PID_FILE.write_text(str(os.getpid()))

def handle_signal(sig, frame):
    log("Shift monitor stopping")
    PID_FILE.unlink(missing_ok=True)
    sys.exit(0)

signal.signal(signal.SIGTERM, handle_signal)
signal.signal(signal.SIGINT, handle_signal)

def load_schedule():
    if not SCHEDULE_FILE.exists():
        return []
    try:
        data = json.loads(SCHEDULE_FILE.read_text())
        return data.get("shifts", [])
    except Exception:
        return []

def parse_shift(s):
    date = datetime.strptime(s["date"], "%Y-%m-%d")
    start_h, start_m = map(int, s["start"].split(":"))
    start_dt = date.replace(hour=start_h, minute=start_m)
    return start_dt

last_alerted_shift = None

log(f"Shift monitor started (PID={os.getpid()}), checking every 30 minutes")

try:
    while True:
        now = datetime.now()
        shifts = load_schedule()

        for s in shifts:
            start_dt = parse_shift(s)
            diff = (start_dt - now).total_seconds()
            mins_until = diff / 60

            # Alert if shift starts within 60 minutes and we haven't alerted for this one
            shift_key = f"{s['date']}_{s['start']}"
            if 0 < mins_until <= 60 and shift_key != last_alerted_shift:
                mins = int(mins_until)
                log(f"Shift alert: {s['type']} shift starts in {mins} minutes")

                subprocess.Popen(
                    ["termux-tts-speak", f"Your {s['type']} shift starts in {mins} minutes. Running focus mode."],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL
                )

                # Wait for TTS to finish before running macro
                time.sleep(5)

                subprocess.Popen(
                    [os.path.expanduser("~/bin/voice-macro"), "focus mode"],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL
                )

                last_alerted_shift = shift_key
                log("Focus mode triggered")

        time.sleep(1800)  # 30 minutes

except Exception as e:
    log(f"Fatal error: {e}")
finally:
    PID_FILE.unlink(missing_ok=True)
    log("Shift monitor stopped")
